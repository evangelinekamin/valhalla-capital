# Database
DATABASE_PATH=data/openinsider.db

# Scraper
SCRAPER_BASE_URL=http://openinsider.com
SCRAPER_TIMEOUT=30
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
RATE_LIMIT_DELAY=2.0
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF=2.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/openinsider.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Discord Alerts (Optional)
DISCORD_WEBHOOK_URL=
DISCORD_ALERT_THRESHOLD=10
