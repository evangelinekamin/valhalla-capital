# Valhalla Capital Dashboard Configuration
# Copy to .env and adjust as needed

# Server
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050

# Dashboard's own database (SQLite path, relative to working directory)
DASHBOARD_DB=valhalla_capital.db

# Health check interval in seconds
POLL_INTERVAL=60

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Public dashboard mode
# When true, internal host/error details are hidden and manual checks are disabled
PUBLIC_DASHBOARD=false
EXPOSE_INTERNAL_DETAILS=true
ALLOW_MANUAL_CHECKS=true
SLOW_REQUEST_MS=500
SSH_KEY_PATH=/opt/valhalla-capital/.ssh/id_ed25519
SSH_KNOWN_HOSTS_PATH=/opt/valhalla-capital/.ssh/known_hosts

# ── Authentication ──
# Leave SESSION_SECRET empty to disable auth (backward compatible — uses static PUBLIC_DASHBOARD mode)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=
# Generate with: python -m app.auth hash
OWNER_PASSWORD_HASH=
SESSION_TTL_DAYS=7

# ── Overseer PostgreSQL (<LAN_IP>) ──
# Valkyrie's brain: cycle_logs, decision_journal, episodic_memory
OVERSEER_DB_HOST=<LAN_IP>
OVERSEER_DB_PORT=5432
OVERSEER_DB_NAME=overseer
OVERSEER_DB_USER=readonly
OVERSEER_DB_PASSWORD=

# ── Trading PostgreSQL (<LAN_IP>) ──
# Execution: trades, positions, portfolio_snapshots
TRADING_DB_HOST=<LAN_IP>
TRADING_DB_PORT=5432
TRADING_DB_NAME=trading
TRADING_DB_USER=readonly
TRADING_DB_PASSWORD=
