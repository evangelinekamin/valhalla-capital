# Environment variables for Twitter Monitoring System
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Miniflux Database
# Generate with: openssl rand -hex 32
MINIFLUX_DB_PASSWORD=

# Miniflux Admin Account
MINIFLUX_ADMIN_USER=admin
# Generate with: openssl rand -hex 16
MINIFLUX_ADMIN_PASSWORD=

# Miniflux API Key (get this AFTER first startup)
# 1. Start services: docker compose up -d
# 2. Login to Miniflux: http://localhost:8081
# 3. Go to Settings -> API Keys -> Create new key
# 4. Paste the key here and restart scraper: docker compose restart scraper
MINIFLUX_API_KEY=

# Miniflux URL
# Host-run scraper should use the host-mapped port.
# Docker scraper service already overrides this with http://miniflux:8080
MINIFLUX_URL=http://localhost:8081

# Processing Database
# Generate with: openssl rand -hex 32
PROCESSING_DB_PASSWORD=

# Anthropic API (for LLM triage)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
