# Required: Anthropic API key (when using anthropic backend)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Discord webhook URL for error monitoring
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: Override config.yaml database path
# DB_PATH=/opt/substack-fetch-process/newsletters.db
