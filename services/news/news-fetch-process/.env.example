# Optional: Environment variable fallbacks
# Primary configuration is in config/feeds.json
# These env vars are only used if the config file fields are empty.

# Anthropic API key for Claude AI classification
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Discord webhook URL for notifications
# Create at: Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
