# IBKR Connection
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password
IBKR_HOST=ib-gateway
IBKR_PORT=4002
IBKR_CLIENT_ID=1
TRADING_MODE=paper

# Database
POSTGRES_PASSWORD=change_me_to_secure_password
DATABASE_URL=postgresql://trading:change_me_to_secure_password@postgres:5432/trading

# Discord Alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# VNC Access (for monitoring IB Gateway)
VNC_PASSWORD=change_me_to_secure_password

# Risk Limits (adjusted for small capital $200-800)
MAX_POSITION_FRACTION=0.20
MAX_DAILY_LOSS_PCT=0.03
MIN_POSITION_SIZE_USD=30
MAX_POSITION_SIZE_USD=2000
MAX_TRADES_PER_DAY=10
MAX_TRADES_PER_WEEK=30

# Shared Volume Paths (internal to container)
TRADE_REQUESTS_PATH=/shared/trade_requests
TRADE_RESULTS_PATH=/shared/trade_results
PORTFOLIO_STATE_PATH=/shared/portfolio_state

# Initial Portfolio Value (for testing)
INITIAL_PORTFOLIO_VALUE=500

# Dry Run Mode (true = simulate trades, false = execute real orders)
DRY_RUN_MODE=true
