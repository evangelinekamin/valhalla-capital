# Yellowbrick Scraper Environment Variables

# Database path
DATABASE_PATH=./data/yellowbrick.db

# Feed URLs
BIG_MONEY_URL=https://www.joinyellowbrick.com/feeds/top_funds_us
ELITE_URL=https://www.joinyellowbrick.com/feeds/elite_us

# Cookie file (export from browser)
COOKIE_FILE=./data/session_cookies.json

# Discord webhook (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Playwright settings
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# Rate limiting (seconds)
DELAY_BETWEEN_FEEDS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/yellowbrick.log
